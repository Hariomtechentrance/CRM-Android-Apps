# NEVER commit .env file with actual secrets - this is an example only
# Copy this to .env and fill in your actual values

# API Configuration
API_BASE_URL=https://api.flowcrm.com
API_TIMEOUT_SECONDS=30
API_MAX_RETRIES=3

# Firebase Configuration
FIREBASE_PROJECT_ID=flowcrm-project
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=flowcrm.firebaseapp.com
FIREBASE_STORAGE_BUCKET=flowcrm.appspot.com

# AI Endpoints (Rate limited)
AI_ENDPOINT_URL=https://api.flowcrm.com/v1/ai
AI_RATE_LIMIT_REQUESTS=10
AI_RATE_LIMIT_WINDOW_MINUTES=1

# Security Settings
ENABLE_SSL_PINNING=true
CERTIFICATE_PIN_SHA256=your_certificate_sha256_here
ENABLE_PROXY_DETECTION=true
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# File Upload Settings
MAX_UPLOAD_SIZE_MB=50
ALLOWED_UPLOAD_EXTENSIONS=pdf,doc,docx,xls,xlsx,jpg,jpeg,png
UPLOAD_TEMP_DIRECTORY=/tmp/uploads

# Logging
LOG_LEVEL=info
LOG_TO_FILE=false
